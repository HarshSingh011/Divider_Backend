# Environment Configuration
# Copy this file to .env and fill in your values

# Server
SERVER_PORT=:8080

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# Database Configuration
# Options: "memory" (default) or "postgres"
DB_DRIVER=memory

# PostgreSQL Connection Settings
# For Neon: Use the connection string from Neon console
# Format: postgresql://user:password@host/dbname?sslmode=require
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=stocktrack
DB_SSLMODE=disable  # Use "require" for Neon/production

# Example Neon setup (uncomment to use):
# DB_DRIVER=postgres
# DB_HOST=ep-xxxx.neon.tech
# DB_PORT=5432
# DB_USER=neon_user
# DB_PASSWORD=neon_password
# DB_NAME=neon_db
# DB_SSLMODE=require
